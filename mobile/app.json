{
  "expo": {
    "name": "Stravy",
    "slug": "stravy",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "stravy",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F1115",
    "splash": {
      "backgroundColor": "#0F1115",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.stravy.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stravy.app"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Stravy to use your location to record activities."
        }
      ],
      "expo-localization"
    ]
  }
}
